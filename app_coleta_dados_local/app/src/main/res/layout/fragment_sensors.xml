<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Clima -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clima"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Temperatura: -- °C"/>
                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Umidade: -- %"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pressão -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pressão Barométrica"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                <TextView
                    android:id="@+id/tvPressure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pressão: -- hPa"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Inercial -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inercial"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acelerômetro (m/s²)"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:id="@+id/tvAccelX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="X: --"/>
                <TextView
                    android:id="@+id/tvAccelY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Y: --"/>
                <TextView
                    android:id="@+id/tvAccelZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Z: --"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giroscópio (rad/s)"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:id="@+id/tvGyroX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="X: --"/>
                <TextView
                    android:id="@+id/tvGyroY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Y: --"/>
                <TextView
                    android:id="@+id/tvGyroZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Z: --"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
