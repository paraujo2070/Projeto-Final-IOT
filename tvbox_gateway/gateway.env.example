GATEWAY_ID=tvbox-sala-01

LOCAL_BROKER_HOST=127.0.0.1
LOCAL_BROKER_PORT=1883
LOCAL_BROKER_USERNAME=
LOCAL_BROKER_PASSWORD=
LOCAL_TOPIC_FILTER=telemetry
LOCAL_CLIENT_ID=tvbox-sala-01-local-subscriber

CLOUD_BROKER_HOST=test.mosquitto.org
CLOUD_BROKER_PORT=1883
CLOUD_BROKER_USERNAME=
CLOUD_BROKER_PASSWORD=
CLOUD_CLIENT_ID=tvbox-sala-01-cloud-forwarder
CLOUD_TOPIC_PREFIX=cloud/

SQLITE_PATH=/var/lib/tvbox-gateway/outbox.db
FORWARD_INTERVAL_SECONDS=5
PUBLISH_QOS=1
STATUS_TOPIC=gateway/tvbox-sala-01/status
LOG_LEVEL=INFO
